            android:layout_height="wrap_content" android:gravity="center" android:textSize="20sp"/>
        <ImageView android:id="@+id/smallIcon4" android:layout_width="28dp"
            android:layout_height="28dp" android:layout_marginStart="4dp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/smallName4" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
