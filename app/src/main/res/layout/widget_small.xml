        <TextView android:id="@+id/smallCheck6" android:layout_width="24dp"
            android:layout_height="wrap_content" android:gravity="center" android:textSize="20sp"/>
        <ImageView android:id="@+id/smallIcon6" android:layout_width="28dp"
            android:layout_height="28dp" android:layout_marginStart="4dp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/smallName6" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="20sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end"/>
    </LinearLayout>

    <!-- 행 7 -->
    <LinearLayout android:id="@+id/smallRow7"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="2dp">
        <TextView android:id="@+id/smallCheck7" android:layout_width="24dp"
            android:layout_height="wrap_content" android:gravity="center" android:textSize="20sp"/>
        <ImageView android:id="@+id/smallIcon7" android:layout_width="28dp"
            android:layout_height="28dp" android:layout_marginStart="4dp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/smallName7" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="20sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end"/>
    </LinearLayout>

    <!-- 행 8 -->
    <LinearLayout android:id="@+id/smallRow8"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="2dp">
        <TextView android:id="@+id/smallCheck8" android:layout_width="24dp"
            android:layout_height="wrap_content" android:gravity="center" android:textSize="20sp"/>
        <ImageView android:id="@+id/smallIcon8" android:layout_width="28dp"
            android:layout_height="28dp" android:layout_marginStart="4dp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/smallName8" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
